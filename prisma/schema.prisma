generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── MASTER DATA ─────────────────────────────────────────────────────────────

model Rokok {
  id               String   @id @default(cuid())
  nama             String   @unique
  stok             Int      @default(0)
  harga_beli       Int
  harga_grosir     Int
  harga_toko       Int
  harga_perorangan Int
  aktif            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  returItems  ReturItem[]
  keluarItems PenjualanKeluar[]
  masukItems  PenjualanMasuk[]
}

model Sales {
  id        String   @id @default(cuid())
  nama      String   @unique
  no_hp     String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  penjualan Penjualan[]
  retur     Retur[]
  absensi   Absensi[]
}

model Toko {
  id        String   @id @default(cuid())
  nama      String   @unique
  tipe      String   // "Toko" | "Grosir"
  alamat    String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  penjualan Penjualan[]
}

// ─── TRANSAKSI ───────────────────────────────────────────────────────────────

model Penjualan {
  id            String   @id @default(cuid())
  tanggal       DateTime @db.Date
  sales_id      String
  toko_id       String?  // nullable untuk kompatibilitas migrasi
  setoran_tipe  String?  // "Cash" | "Transfer"
  setoran_total Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  sales       Sales             @relation(fields: [sales_id], references: [id])
  toko        Toko?             @relation(fields: [toko_id], references: [id])
  keluarItems PenjualanKeluar[]
  masukItems  PenjualanMasuk[]
}

model PenjualanKeluar {
  id           String @id @default(cuid())
  penjualan_id String
  rokok_id     String
  qty          Int
  qty_sample   Int    @default(0)

  penjualan Penjualan @relation(fields: [penjualan_id], references: [id], onDelete: Cascade)
  rokok     Rokok     @relation(fields: [rokok_id], references: [id])
}

model PenjualanMasuk {
  id           String @id @default(cuid())
  penjualan_id String
  rokok_id     String
  qty          Int
  qty_sample   Int    @default(0)
  harga        Int    @default(0)
  pembayaran   String @default("Cash") // "Cash" | "Transfer" | "Hutang"

  penjualan Penjualan @relation(fields: [penjualan_id], references: [id], onDelete: Cascade)
  rokok     Rokok     @relation(fields: [rokok_id], references: [id])
}

model Retur {
  id             String   @id @default(cuid())
  tanggal        DateTime @db.Date
  tipe_penjualan String   // "Toko" | "Grosir" | "Perorangan"
  sales_id       String
  alasan         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sales Sales       @relation(fields: [sales_id], references: [id])
  items ReturItem[]
}

model ReturItem {
  id       String @id @default(cuid())
  retur_id String
  rokok_id String
  qty      Int

  retur Retur @relation(fields: [retur_id], references: [id], onDelete: Cascade)
  rokok Rokok @relation(fields: [rokok_id], references: [id])
}

model Pengeluaran {
  id         String   @id @default(cuid())
  tanggal    DateTime @db.Date
  jumlah     Int
  keterangan String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Absensi {
  id        String   @id @default(cuid())
  tanggal   DateTime @db.Date
  sales_id  String
  status    String   // "hadir" | "izin" | "alpha"
  reason    String?
  createdAt DateTime @default(now())

  sales Sales @relation(fields: [sales_id], references: [id])

  @@unique([tanggal, sales_id])
}
