generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  role      String   @default("staff") // "superadmin" | "admin" | "staff"
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stockMutations StockMutation[]
  auditLogs      AuditLog[]
}

// ─── MASTER DATA ─────────────────────────────────────────────────────────────

model Toko {
  id        String   @id @default(cuid())
  nama      String   @unique
  alamat    String?
  kategori  String   @default("toko") // "grosir" | "toko"
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  titipJual TitipJual[]
}

model Rokok {
  id               String   @id @default(cuid())
  nama             String   @unique
  stok             Int      @default(0)
  harga_beli       Int
  harga_grosir     Int
  harga_toko       Int
  harga_perorangan Int
  aktif            Boolean  @default(true)
  urutan           Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sesiBarangKeluar    SesiBarangKeluar[]
  sesiPenjualan       SesiPenjualan[]
  sesiBarangKembali   SesiBarangKembali[]
  titipJualItems      TitipJualItem[]
  returItems          ReturItem[]
  stokMasuk           StokMasuk[]
  stockMutations      StockMutation[]
  closingHarian       ClosingHarian[]
  tukarBarangMasuk    TukarBarangItemMasuk[]
  tukarBarangKeluar   TukarBarangItemKeluar[]
}

model StokMasuk {
  id         String   @id @default(cuid())
  rokok_id   String
  tanggal    DateTime @db.Date
  qty        Int
  keterangan String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rokok Rokok @relation(fields: [rokok_id], references: [id], onDelete: Cascade)
}

model Sales {
  id        String   @id @default(cuid())
  nama      String   @unique
  no_hp     String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sesi      SesiHarian[]
  titipJual TitipJual[]
  absensi   Absensi[]
  retur     Retur[]
}

// ─── DISTRIBUSI ───────────────────────────────────────────────────────────────

model SesiHarian {
  id        String   @id @default(cuid())
  tanggal   DateTime @db.Date
  sales_id  String
  status    String   @default("aktif") // "aktif" | "selesai"
  catatan   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales              Sales              @relation(fields: [sales_id], references: [id])
  barangKeluar       SesiBarangKeluar[]
  penjualan          SesiPenjualan[]
  setoran            SesiSetoran[]
  barangKembali      SesiBarangKembali[]
  titipJual          TitipJual[]
  tukarBarang        TukarBarang[]      @relation("TukarBarangSesi")
  tukarBarangSelesai TukarBarang[]      @relation("TukarBarangSesiSelesai")

  @@unique([tanggal, sales_id])
}

model SesiBarangKeluar {
  id       String @id @default(cuid())
  sesi_id  String
  rokok_id String
  qty      Int

  sesi  SesiHarian @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  rokok Rokok      @relation(fields: [rokok_id], references: [id])
}

model SesiPenjualan {
  id       String @id @default(cuid())
  sesi_id  String
  rokok_id String
  kategori String // "grosir" | "toko" | "perorangan"
  qty      Int
  harga    Int

  sesi  SesiHarian @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  rokok Rokok      @relation(fields: [rokok_id], references: [id])
}

model SesiSetoran {
  id      String @id @default(cuid())
  sesi_id String
  metode  String // "cash" | "transfer"
  jumlah  Int

  sesi SesiHarian @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
}

model SesiBarangKembali {
  id       String @id @default(cuid())
  sesi_id  String
  rokok_id String
  qty      Int

  sesi  SesiHarian @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  rokok Rokok      @relation(fields: [rokok_id], references: [id])
}

// ─── TITIP JUAL ───────────────────────────────────────────────────────────────

model TitipJual {
  id                  String   @id @default(cuid())
  sesi_id             String
  sales_id            String
  toko_id             String
  kategori            String   // "grosir" | "toko"
  tanggal_jatuh_tempo DateTime  @db.Date
  tanggal_selesai     DateTime? @db.Date
  status              String    @default("aktif") // "aktif" | "selesai"
  flag_selisih_setoran Boolean   @default(false)
  catatan             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sesi    SesiHarian      @relation(fields: [sesi_id], references: [id])
  sales   Sales           @relation(fields: [sales_id], references: [id])
  toko    Toko            @relation(fields: [toko_id], references: [id])
  items   TitipJualItem[]
  setoran TitipJualSetoran[]
}

model TitipJualItem {
  id            String @id @default(cuid())
  titip_jual_id String
  rokok_id      String
  qty_keluar    Int
  qty_terjual   Int    @default(0)
  qty_kembali   Int    @default(0)
  harga         Int

  titipJual TitipJual @relation(fields: [titip_jual_id], references: [id], onDelete: Cascade)
  rokok     Rokok     @relation(fields: [rokok_id], references: [id])
}

model TitipJualSetoran {
  id                   String   @id @default(cuid())
  titip_jual_id        String
  metode               String   // "cash" | "transfer"
  jumlah               Int
  tanggal              DateTime @db.Date
  sesi_penyelesaian_id String?

  titipJual TitipJual @relation(fields: [titip_jual_id], references: [id], onDelete: Cascade)
}

// ─── LAINNYA ──────────────────────────────────────────────────────────────────

model Pengeluaran {
  id         String   @id @default(cuid())
  tanggal    DateTime @db.Date
  jumlah     Int
  keterangan String
  sumber     String   @default("penjualan") // "penjualan" | "lainnya"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Absensi {
  id        String   @id @default(cuid())
  tanggal   DateTime @db.Date
  sales_id  String
  status    String   // "hadir" | "izin" | "alpha" | "sakit"
  reason    String?
  createdAt DateTime @default(now())

  sales Sales @relation(fields: [sales_id], references: [id])

  @@unique([tanggal, sales_id])
}

// ─── RETUR ───────────────────────────────────────────────────────────────────

model Retur {
  id             String   @id @default(cuid())
  tanggal        DateTime @db.Date
  tipe_penjualan String?
  sales_id       String
  alasan         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sales Sales       @relation(fields: [sales_id], references: [id])
  items ReturItem[]
}

model ReturItem {
  id       String @id @default(cuid())
  retur_id String
  rokok_id String
  qty      Int

  retur Retur @relation(fields: [retur_id], references: [id], onDelete: Cascade)
  rokok Rokok @relation(fields: [rokok_id], references: [id])
}

// ─── TUKAR BARANG ────────────────────────────────────────────────────────────
// Toko menukar rokok yg sudah dia beli dengan rokok yg dibawa sales hari itu.
// Selisih harga bisa positif (toko bayar tambahan) / negatif (sales kasih kembalian) / nol.

model TukarBarang {
  id              String    @id @default(cuid())
  tanggal         DateTime  @db.Date          // hari-1, saat tukar dibuat (B diserahkan toko)
  sesi_id         String                       // sesi sales hari-1
  sesi_selesai_id String?                      // sesi sales hari-N (saat tukar diselesaikan)
  status          String    @default("aktif")  // "aktif" | "selesai"
  kategori        String    @default("grosir") // "grosir" | "toko"
  tanggal_selesai DateTime? @db.Date           // hari-N, null kalau masih aktif
  selisih_uang    Int       @default(0)        // positif: toko bayar tambahan, negatif: sales kasih kembalian
  catatan         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sesi         SesiHarian              @relation("TukarBarangSesi", fields: [sesi_id], references: [id])
  sesiSelesai  SesiHarian?             @relation("TukarBarangSesiSelesai", fields: [sesi_selesai_id], references: [id])
  itemsMasuk   TukarBarangItemMasuk[]  // rokok dari toko (kembali, fisik di hari-1)
  itemsKeluar  TukarBarangItemKeluar[] // rokok dari sales (planned di hari-1, fisik di hari-N)

  @@index([tanggal])
  @@index([sesi_id])
  @@index([status])
}

model TukarBarangItemMasuk {
  id              String @id @default(cuid())
  tukar_id        String
  rokok_id        String
  qty             Int
  harga_satuan    Int    // harga per pcs/slop saat tukar (auto-fill dari master, editable)

  tukar TukarBarang @relation(fields: [tukar_id], references: [id], onDelete: Cascade)
  rokok Rokok       @relation(fields: [rokok_id], references: [id])
}

model TukarBarangItemKeluar {
  id              String @id @default(cuid())
  tukar_id        String
  rokok_id        String
  qty             Int
  harga_satuan    Int    // harga jual saat tukar (auto-fill dari master, editable)

  tukar TukarBarang @relation(fields: [tukar_id], references: [id], onDelete: Cascade)
  rokok Rokok       @relation(fields: [rokok_id], references: [id])
}

// ─── STOK (LEDGER BASED) ────────────────────────────────────────────────────────

model StockMutation {
  id           String   @id @default(cuid())
  rokok_id     String
  tanggal      DateTime @db.Date
  jenis        String   // "in" | "out"
  qty          Int
  source       String   // "stok_awal", "adjustment", "koreksi", "penjualan", "distribusi_sales", "retur_sales", "retur", "konsinyasi_keluar", "konsinyasi_kembali", "tukar_masuk", "tukar_keluar"
  reference_id String?  // Optional: ID transaksi asal
  keterangan   String?  // Optional: Catatan tambahan untuk mutasi ini
  user_id      String?  // Optional: User yang melakukan mutasi
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  rokok Rokok @relation(fields: [rokok_id], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [user_id], references: [id])

  @@index([rokok_id, tanggal])
}

model ClosingHarian {
  id         String   @id @default(cuid())
  tanggal    DateTime @db.Date
  rokok_id   String
  stok_akhir Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt

  rokok Rokok @relation(fields: [rokok_id], references: [id], onDelete: Cascade)

  @@unique([tanggal, rokok_id])
}

// ─── AUDIT LOG ───────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  entity_type String   // "SesiHarian" | "TitipJual" | "Pengeluaran" | "Rokok" | "TukarBarang"
  change_type String?  // misal: "Laporan Sore - Setoran", "Perpanjang JT", dll
  entity_id   String
  action      String   // "CREATE" | "UPDATE" | "DELETE"
  old_values  Json?
  new_values  Json?
  alasan      String?
  user_id     String?
  user_name   String?  // disimpan langsung agar tetap ada meski user dihapus
  createdAt   DateTime @default(now())

  user User? @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([entity_type, entity_id])
  @@index([createdAt])
}
