generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTH ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── MASTER DATA ─────────────────────────────────────────────────────────────

model Toko {
  id        String   @id @default(cuid())
  nama      String   @unique
  alamat    String?
  kategori  String   @default("toko") // "grosir" | "toko"
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  konsinyasi Konsinyasi[]
}

model Rokok {
  id               String   @id @default(cuid())
  nama             String   @unique
  stok             Int      @default(0)
  harga_beli       Int
  harga_grosir     Int
  harga_toko       Int
  harga_perorangan Int
  aktif            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sesiBarangKeluar  SesiBarangKeluar[]
  sesiPenjualan     SesiPenjualan[]
  sesiBarangKembali SesiBarangKembali[]
  konsinyasiItems   KonsinyasiItem[]
  returItems        ReturItem[]
}

model Sales {
  id        String   @id @default(cuid())
  nama      String   @unique
  no_hp     String?
  aktif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sesi       SesiHarian[]
  konsinyasi Konsinyasi[]
  absensi    Absensi[]
  retur      Retur[]
}

// ─── DISTRIBUSI ───────────────────────────────────────────────────────────────

model SesiHarian {
  id        String   @id @default(cuid())
  tanggal   DateTime @db.Date
  sales_id  String
  status    String   @default("aktif") // "aktif" | "selesai"
  catatan   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales         Sales              @relation(fields: [sales_id], references: [id])
  barangKeluar  SesiBarangKeluar[]
  penjualan     SesiPenjualan[]
  setoran       SesiSetoran[]
  barangKembali SesiBarangKembali[]
  konsinyasi    Konsinyasi[]

  @@unique([tanggal, sales_id])
}

model SesiBarangKeluar {
  id       String @id @default(cuid())
  sesi_id  String
  rokok_id String
  qty      Int

  sesi  SesiHarian @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  rokok Rokok      @relation(fields: [rokok_id], references: [id])
}

model SesiPenjualan {
  id       String @id @default(cuid())
  sesi_id  String
  rokok_id String
  kategori String // "grosir" | "toko" | "perorangan"
  qty      Int
  harga    Int

  sesi  SesiHarian @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  rokok Rokok      @relation(fields: [rokok_id], references: [id])
}

model SesiSetoran {
  id      String @id @default(cuid())
  sesi_id String
  metode  String // "cash" | "transfer"
  jumlah  Int

  sesi SesiHarian @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
}

model SesiBarangKembali {
  id       String @id @default(cuid())
  sesi_id  String
  rokok_id String
  qty      Int

  sesi  SesiHarian @relation(fields: [sesi_id], references: [id], onDelete: Cascade)
  rokok Rokok      @relation(fields: [rokok_id], references: [id])
}

// ─── KONSINYASI ───────────────────────────────────────────────────────────────

model Konsinyasi {
  id                  String   @id @default(cuid())
  sesi_id             String
  sales_id            String
  toko_id             String
  kategori            String   // "grosir" | "toko"
  tanggal_jatuh_tempo DateTime  @db.Date
  tanggal_selesai     DateTime? @db.Date
  status              String    @default("aktif") // "aktif" | "selesai"
  catatan             String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sesi    SesiHarian          @relation(fields: [sesi_id], references: [id])
  sales   Sales               @relation(fields: [sales_id], references: [id])
  toko    Toko                @relation(fields: [toko_id], references: [id])
  items   KonsinyasiItem[]
  setoran KonsinyasiSetoran[]
}

model KonsinyasiItem {
  id            String @id @default(cuid())
  konsinyasi_id String
  rokok_id      String
  qty_keluar    Int
  qty_terjual   Int    @default(0)
  qty_kembali   Int    @default(0)
  harga         Int

  konsinyasi Konsinyasi @relation(fields: [konsinyasi_id], references: [id], onDelete: Cascade)
  rokok      Rokok      @relation(fields: [rokok_id], references: [id])
}

model KonsinyasiSetoran {
  id                   String   @id @default(cuid())
  konsinyasi_id        String
  metode               String   // "cash" | "transfer"
  jumlah               Int
  tanggal              DateTime @db.Date
  sesi_penyelesaian_id String?

  konsinyasi Konsinyasi @relation(fields: [konsinyasi_id], references: [id], onDelete: Cascade)
}

// ─── LAINNYA ──────────────────────────────────────────────────────────────────

model Pengeluaran {
  id         String   @id @default(cuid())
  tanggal    DateTime @db.Date
  jumlah     Int
  keterangan String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Absensi {
  id        String   @id @default(cuid())
  tanggal   DateTime @db.Date
  sales_id  String
  status    String   // "hadir" | "izin" | "alpha"
  reason    String?
  createdAt DateTime @default(now())

  sales Sales @relation(fields: [sales_id], references: [id])

  @@unique([tanggal, sales_id])
}

// ─── RETUR ───────────────────────────────────────────────────────────────────

model Retur {
  id             String   @id @default(cuid())
  tanggal        DateTime @db.Date
  tipe_penjualan String?
  sales_id       String
  alasan         String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sales Sales       @relation(fields: [sales_id], references: [id])
  items ReturItem[]
}

model ReturItem {
  id       String @id @default(cuid())
  retur_id String
  rokok_id String
  qty      Int

  retur Retur @relation(fields: [retur_id], references: [id], onDelete: Cascade)
  rokok Rokok @relation(fields: [rokok_id], references: [id])
}

